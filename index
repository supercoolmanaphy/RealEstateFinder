<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ParcellIQ — Off-Market Leads for Bay Area Realtors</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #FAF8F3;
      --dark: #1A1A16;
      --gold: #C4892A;
      --gold-light: #F0C56A;
      --rust: #8B3A1E;
      --sage: #3D5A47;
      --muted: #6B6860;
      --border: #E2DDD4;
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--dark); }

    /* NAV */
    nav { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; border-bottom: 0.5px solid var(--border); }
    .logo { font-family: 'DM Serif Display', serif; font-size: 1.2rem; }
    .logo em { font-style: italic; }
    .logo sup { font-family: 'DM Sans', sans-serif; font-size: 9px; color: var(--gold); vertical-align: super; letter-spacing: 0.1em; text-transform: uppercase; }
    .nav-links { display: flex; gap: 1.5rem; font-size: 12px; color: var(--muted); }
    .nav-links a { text-decoration: none; color: inherit; }
    .nav-links a.cta { color: var(--dark); font-weight: 500; }

    /* TICKER */
    .ticker { background: var(--dark); color: var(--cream); padding: 0.5rem 2rem; font-size: 11px; letter-spacing: 0.04em; display: flex; gap: 2rem; overflow: hidden; }
    .ticker-item { white-space: nowrap; display: flex; gap: 8px; align-items: center; }
    .badge { padding: 1px 6px; border-radius: 2px; font-size: 10px; }
    .badge.tax { background: var(--rust); }
    .badge.pre { background: #8B1C1C; }
    .badge.new { background: var(--sage); }

    /* HERO */
    .hero { padding: 4rem 2rem 3rem; text-align: center; border-bottom: 0.5px solid var(--border); }
    .eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 1.2rem; }
    h1 { font-family: 'DM Serif Display', serif; font-size: clamp(2.4rem, 5vw, 3.6rem); line-height: 1.12; max-width: 640px; margin: 0 auto 1.2rem; }
    h1 em { font-style: italic; color: var(--rust); }
    .sub { font-size: 1.05rem; color: var(--muted); max-width: 480px; margin: 0 auto 2rem; line-height: 1.7; }
    .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary { background: var(--dark); color: var(--cream); border: none; padding: 14px 28px; border-radius: 4px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn-secondary { background: transparent; color: var(--dark); border: 0.5px solid #999; padding: 14px 28px; border-radius: 4px; font-family: 'DM Sans', sans-serif; font-size: 14px; cursor: pointer; text-decoration: none; display: inline-block; }

    /* TRUST BAR */
    .trust-bar { display: flex; gap: 2rem; justify-content: center; padding: 1.5rem 2rem; border-bottom: 0.5px solid var(--border); flex-wrap: wrap; }
    .trust-item { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 6px; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sage); }

    /* SECTIONS */
    section { padding: 3rem 2rem; border-bottom: 0.5px solid var(--border); }
    .section-label { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
    h2 { font-family: 'DM Serif Display', serif; font-size: clamp(1.6rem, 3vw, 2.2rem); line-height: 1.2; margin-bottom: 1.5rem; }

    /* STATS */
    .stat-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1px; background: var(--border); border: 0.5px solid var(--border); margin-bottom: 2rem; }
    .stat-box { background: var(--cream); padding: 1.2rem 1.5rem; }
    .stat-num { font-family: 'DM Serif Display', serif; font-size: 2rem; color: var(--dark); }
    .stat-lbl { font-size: 11px; color: var(--muted); margin-top: 2px; letter-spacing: 0.04em; }

    /* MAP PLACEHOLDER */
    .map-placeholder { background: #EEE9DF; border: 0.5px solid var(--border); height: 200px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; margin-bottom: 1rem; border-radius: 4px; }
    .map-dot { position: absolute; width: 8px; height: 8px; border-radius: 50%; border: 1.5px solid var(--dark); }
    .map-dot.d { background: #F0A83C; }
    .map-dot.p { background: #D9534F; }
    .map-legend { display: flex; gap: 1.2rem; font-size: 11px; color: var(--muted); }
    .legend-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 4px; vertical-align: middle; }

    /* LEAD CARDS */
    .lead-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1px; background: var(--border); border: 0.5px solid var(--border); }
    .lead-card { background: var(--cream); padding: 1.5rem; cursor: pointer; transition: background 0.15s; }
    .lead-card:hover { background: #F3EFE6; }
    .lead-card.blurred { filter: blur(3px); pointer-events: none; user-select: none; }
    .lead-tag { display: inline-block; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 8px; border-radius: 2px; margin-bottom: 10px; font-weight: 500; }
    .tag-delinquent { background: #FEF0E0; color: #944E0A; }
    .tag-preforeclosure { background: #FBEAEA; color: #8B1C1C; }
    .tag-absentee { background: #EAF2EE; color: #1D5E36; }
    .lead-addr { font-size: 14px; font-weight: 500; margin-bottom: 4px; }
    .lead-meta { font-size: 12px; color: var(--muted); line-height: 1.6; }
    .lead-val { font-family: 'DM Serif Display', serif; font-size: 1.4rem; margin-top: 8px; }
    .lead-val span { font-family: 'DM Sans', sans-serif; font-size: 11px; color: var(--muted); font-weight: 400; margin-left: 4px; }
    .unlock-note { margin-top: 1rem; font-size: 12px; color: var(--muted); text-align: center; }

    /* FEATURES */
    .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
    .feat { padding: 1.25rem; border: 0.5px solid var(--border); }
    .feat h3 { font-size: 14px; font-weight: 500; margin-bottom: 6px; margin-top: 10px; }
    .feat p { font-size: 12px; color: var(--muted); line-height: 1.6; }

    /* PRICING */
    .plans { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1px; background: var(--border); border: 0.5px solid var(--border); }
    .plan { background: var(--cream); padding: 1.5rem; }
    .plan.featured { background: var(--dark); color: var(--cream); }
    .plan-name { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.5rem; }
    .plan.featured .plan-name { color: var(--gold); }
    .plan-price { font-family: 'DM Serif Display', serif; font-size: 2.2rem; line-height: 1; margin-bottom: 0.3rem; }
    .plan-sub { font-size: 11px; margin-bottom: 1.2rem; color: var(--muted); }
    .plan.featured .plan-sub { color: #AAA; }
    .plan-features { list-style: none; font-size: 12px; line-height: 2; }
    .plan.featured .plan-features { color: #CCC; }
    .plan-btn { margin-top: 1.5rem; width: 100%; padding: 10px; font-family: 'DM Sans', sans-serif; font-size: 13px; cursor: pointer; border-radius: 2px; font-weight: 500; display: block; text-align: center; text-decoration: none; }
    .btn-dark { background: var(--cream); color: var(--dark); border: none; }
    .btn-light { background: transparent; color: var(--dark); border: 0.5px solid #BBB; }

    footer { padding: 1.5rem 2rem; text-align: center; font-size: 11px; color: var(--muted); border-top: 0.5px solid var(--border); }
  </style>
</head>
