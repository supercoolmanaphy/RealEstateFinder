# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key  # keep secret — server-side only

# ── ATTOM Data API ────────────────────────────────────────────────────────────
# Get your key from: https://api.attomdata.com
ATTOM_API_KEY=your-attom-api-key

# ── Stripe (for subscription billing) ────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# ── Harvester settings ────────────────────────────────────────────────────────
# Number of San Jose ZIP codes to process per ATTOM harvest run (default: 5)
ATTOM_ZIP_LIMIT=5
